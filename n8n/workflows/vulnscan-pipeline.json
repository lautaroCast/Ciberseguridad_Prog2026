    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "function safeGet(nodeName) {\n  try {\n    const items = $(nodeName).all();\n    return items && items.length ? items[0].json : null;\n  } catch (e) {\n    return null;\n  }\n}\n\n// Only one of the two trigger branches actually ran in this execution —\n// referencing the other by name would throw, hence the try/catch above.\n// This is the only node in the workflow that needs to guess which branch\n// fired; everything downstream can reference this node directly.\nconst ctx = safeGet('Edit Fields - From Webhook') || safeGet('Edit Fields - From Manual');\n\nif (!ctx || !ctx.scan_id || !ctx.target_id || !ctx.host) {\n  throw new Error('Pipeline context is incomplete: expected target_id, scan_id and host from either trigger branch.');\n}\n\nreturn [{ json: ctx }];"
      },
      "id": "code-resolve-context",
      "name": "Resolve Pipeline Context",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [280, 50]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "http://scanner:8100/scan/nmap",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ { \"target\": $json.host } }}",
        "options": { "timeout": 60000 }
      },
      "id": "http-scan-nmap",
      "name": "Scan: Nmap",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [500, 50],
      "continueOnFail": true
    },
    {
      "parameters": {
        "method": "POST",
        "url": "=http://backend:8000/scans/{{ $('Resolve Pipeline Context').item.json.scan_id }}/tasks",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ $json }}",
        "options": { "timeout": 30000 }
      },
      "id": "http-ingest-nmap",
      "name": "Ingest: Nmap",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [720, 50],
      "continueOnFail": true
    },
    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const nmapResult = $('Scan: Nmap').item.json;\nconst context = $('Resolve Pipeline Context').item.json;\n\nconst services = (nmapResult && nmapResult.parsed) || [];\n\n// \"Selección inteligente de herramientas\" (etapa 6 del pipeline): si Nmap\n// no encontró ningún puerto abierto, correr las herramientas HTTP no\n// tiene sentido. Devolver 0 items detiene el resto de la cadena.\nif (services.length === 0) {\n  return [];\n}\n\nconst httpService = services.find((s) => /http/i.test(s.service_name || ''));\nconst chosen = httpService || services[0];\nconst scheme = /https/i.test(chosen.service_name || '') ? 'https' : 'http';\n\nreturn [{\n  json: {\n    ...context,\n    port: chosen.port,\n    scheme,\n  },\n}];"
      },

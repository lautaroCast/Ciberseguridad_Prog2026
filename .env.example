# ============================================================================
# VULNSCAN PLATFORM — Environment configuration
# Copy this file to ".env" and adjust values if needed.
# Every service reads its configuration exclusively from environment
# variables so that `docker compose up -d` requires no manual setup.
# ============================================================================

# ---------------------------------------------------------------------------
# General
# ---------------------------------------------------------------------------
# Project namespace used for container names / Docker network prefixes.
COMPOSE_PROJECT_NAME=vulnscan

# Deployment environment: local | ci
ENVIRONMENT=local

# ---------------------------------------------------------------------------
# PostgreSQL (database service)
# ---------------------------------------------------------------------------
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=vulnscan
POSTGRES_USER=vulnscan
POSTGRES_PASSWORD=change_me_local_dev_only

# Full SQLAlchemy-style DSN, consumed by backend/database services.
DATABASE_URL=postgresql+psycopg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# ---------------------------------------------------------------------------
# Backend API
# ---------------------------------------------------------------------------
BACKEND_PORT=8000
BACKEND_SECRET_KEY=change_me_local_dev_only
BACKEND_LOG_LEVEL=info
# Comma-separated origins allowed to call the API (frontend dev/prod URLs).
BACKEND_CORS_ORIGINS=http://localhost:5173,http://localhost:8080
# Whitelist enforced when registering targets: only these hostnames
# (resolvable on lab-network) can ever be scanned. Add a host here when a
# new lab target is added in lab/ (Módulo 2).
BACKEND_ALLOWED_LAB_HOSTS=juice-shop,dvwa

# ---------------------------------------------------------------------------
# Scanner Service
# ---------------------------------------------------------------------------
SCANNER_PORT=8100
# Hard upper bound (seconds) for any single tool execution, enforced by the
# scanner service regardless of what the caller requests.
SCANNER_MAX_TIMEOUT_SECONDS=900

# ---------------------------------------------------------------------------
# Reports Service
# ---------------------------------------------------------------------------
REPORTS_PORT=8200
REPORTS_OUTPUT_DIR=/data/reports
REPORTS_BASE_URL=http://reports:8200

# ---------------------------------------------------------------------------
# n8n
# ---------------------------------------------------------------------------
N8N_PORT=5678
N8N_HOST=localhost
N8N_PROTOCOL=http
N8N_ENCRYPTION_KEY=change_me_local_dev_only
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change_me_local_dev_only
# Base URL the backend uses to reach n8n's webhook endpoints.
N8N_WEBHOOK_BASE_URL=http://n8n:5678

# ---------------------------------------------------------------------------
# Frontend
# ---------------------------------------------------------------------------
FRONTEND_PORT=8080
# Base URL the browser uses to reach the backend API.
VITE_API_BASE_URL=http://localhost:8000

# ---------------------------------------------------------------------------
# Lab targets (vulnerable applications — local only, isolated network)
# ---------------------------------------------------------------------------
JUICE_SHOP_PORT=3000
DVWA_PORT=3001
